# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Google / Gmail
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json
GOOGLE_DELEGATED_EMAIL=you@yourdomain.com
GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/gmail-push
GOOGLE_PUBSUB_VERIFICATION_TOKEN=your-random-token

# Google Sheets
GOOGLE_SHEET_ID=your-google-sheet-id

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_MANAGER_CHAT_ID=123456789
TELEGRAM_BOT_LINK=https://t.me/your_bot

# n8n
N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=your-n8n-api-key

# Company (legacy fallback)
COMPANY_NAME=Мебельная компания
COMPANY_PHONE=+7 (999) 123-45-67
COMPANY_WEBSITE=https://yoursite.ru

# Business config
BUSINESS_CONFIG_PATH=configs/business.yaml

# Database (PostgreSQL in Docker, SQLite for local dev)
DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/email_agent
# DATABASE_URL=sqlite+aiosqlite:///./data/agent.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Rate limiting
GMAIL_DAILY_SEND_LIMIT=230

# Response delay (seconds) — human-like delay before replying
REPLY_DELAY_MIN=120
REPLY_DELAY_MAX=900

# Lead enrichment
ENRICHMENT_ENABLED=false

# Observability
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# Multi-account (optional — path to accounts YAML)
ACCOUNTS_CONFIG_PATH=

# Avito (опционально — для привлечения исполнителей)
AVITO_ENABLED=false
AVITO_CLIENT_ID=your-avito-client-id
AVITO_CLIENT_SECRET=your-avito-client-secret
AVITO_USER_ID=your-avito-user-id
AVITO_POLL_INTERVAL=60
AVITO_FUNNEL_CONFIG_PATH=configs/avito_worker_funnel.yaml

# Admin panel
ADMIN_SECRET=your-secret-token-here

# App
APP_BASE_URL=https://agent.yourdomain.com
DEBUG=false
